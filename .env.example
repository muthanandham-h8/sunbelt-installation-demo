EXPO_PUBLIC_OKTA_ISSUER=https://trial-1152722.okta.com
EXPO_PUBLIC_OKTA_CLIENT_ID=YOUR_CLIENT_ID_HERE
EXPO_PUBLIC_OKTA_SCOPES=openid profile email groups
EXPO_PUBLIC_OKTA_REDIRECT_SCHEME=com.installationapp
# Mock Installation API (see server/README.md). Leave blank to use the
# inline mock fallbacks baked into App.js.
EXPO_PUBLIC_DEVICE_API_URL=http://localhost:4000/devices
EXPO_PUBLIC_JOBS_API_URL=http://localhost:4000/jobs

# Server-side Okta verification (see server/README.md). Set OKTA_ISSUER to
# enforce access-token verification on the API; leave unset for open mock mode.
# Org Authorization Server: bare-domain issuer, aud = the org URL itself.
OKTA_ISSUER=https://trial-1152722.okta.com
OKTA_AUDIENCE=https://trial-1152722.okta.com

